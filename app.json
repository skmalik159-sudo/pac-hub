{
  "expo": {
    "name": "PAC Hub",
    "slug": "pac-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A44"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2A44"
      },
      "package": "com.pachub.app",
      "versionCode": 1,
      "permissions": ["READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE"]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pachub.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "PAC Hub ko apki tasveerein post mein lagane ke liye access chahiye."
        }
      ]
    ]
  }
}
